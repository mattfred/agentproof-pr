{
  "name": "agentproof-pr",
  "version": "0.2.2",
  "description": "Stop reviewing half-finished AI-generated pull requests.",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "format": "prettier --write src/**/*.ts test/**/*.ts",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "github-action",
    "pull-request",
    "ai",
    "code-review"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1",
    "js-yaml": "^4.1.0",
    "minimatch": "^9.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}
